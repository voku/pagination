{
  "name": "voku/pagination",
  "type": "library",
  "description": "Pagination, without a database dependency",
  "keywords": [
    "pagination",
    "pager",
    "paginator"
  ],
  "authors": [
    {
      "name": "David Carr",
      "email": "dave@daveismyname.com",
      "homepage": "http://www.daveismyname.com",
      "role": "Developer"
    },
    {
      "name": "Lars Moelleken",
      "email": "lars@moelleken.org",
      "homepage": "http://www.moelleken.org/",
      "role": "Fork-Maintainer"
    }
  ],
  "license": [
    "MIT"
  ],
  "require": {
    "php": "^7.1 || ^8.0"
  },
  "require-dev": {
    "phpstan/phpstan": "^0.12.100 || ^1.12.33 || ^2.1.51",
    "phpunit/phpunit": "^7.5.20 || ^8.5.52 || ^9.6.34 || ^10.5.63 || ^11.5.55 || ^12.5.23"
  },
  "config": {
    "sort-packages": true
  },
  "scripts": {
    "phpstan": "@php vendor/bin/phpstan analyse",
    "test": "@php vendor/bin/phpunit --no-configuration --bootstrap tests/bootstrap.php tests"
  },
  "autoload": {
    "psr-4": {
      "voku\\helper\\": "src/voku/helper/"
    }
  },
  "extra": {
    "branch-alias": {
      "dev-master": "2.1.x-dev"
    }
  }
}
